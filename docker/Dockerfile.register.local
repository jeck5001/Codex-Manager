FROM docker-codexmanager-register:latest

ARG PLAYWRIGHT_BROWSER_INSTALL_ARGS="chromium"

WORKDIR /app

COPY vendor/codex-register/ /app/

ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

RUN pip install --no-cache-dir -r requirements.txt \
    && python -m playwright install ${PLAYWRIGHT_BROWSER_INSTALL_ARGS}

RUN mkdir -p /app/data /app/logs \
    && chmod +x /app/docker/start-register.sh

EXPOSE 9000 7900

ENV PYTHONUNBUFFERED=1

CMD ["/app/docker/start-register.sh"]
